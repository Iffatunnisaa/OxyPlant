<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OxyPlant</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="font-roboto"> 

<!-- Navigation -->
<nav class="bg-[#F2F1EB] shadow-sm py-4 px-6 sticky top-0 z-50" id="main-nav">
    <div class="max-w-6xl mx-auto flex justify-between items-center">
      <!-- Logo -->
      <div class="text-xl md:text-2xl font-bold text-[#0A5436] transition-colors duration-300">OxyPlant</div>
      
      <!-- Desktop Menu -->
      <div class="hidden md:flex space-x-4 lg:space-x-6 items-center">
        <a href="#" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">Home</a>
        <a href="#" class="text-[#3FAB5E] font-semibold transition-colors duration-300 text-sm md:text-base">Garden Manager</a>
        <a href="#" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">Plant Care</a>
        <a href="#" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">Plant Info</a>
        <a href="#" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">About</a>
      </div>
      
      <!-- Mobile Menu Button -->
      <button id="mobile-menu-button" class="md:hidden text-[#F1F0E9] focus:outline-none transition-colors duration-300">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
</nav>

<!-- Hero Section -->
<section class="bg-[#F2F1EB] py-16 md:py-24 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-8 md:gap-12">
      <!-- Text Content (Left) -->
      <div class="md:w-1/2 text-left">
          <h1 class="text-4xl md:text-4xl lg:text-5xl font-bold text-[#0A5436] mb-4">
              Garden Manager
          </h1>
          <p class="mt-4 text-gray-600 max-w-lg leading-relaxed">
              Berkebun Jadi Lebih Seru dan Teratur<br>
              Garden Manager membantumu merawat<br>
              tanaman dengan jadwal otomatis, tips perawatan,<br>
              dan catatan pertumbuhan yang praktis.
          </p>
      </div>

      <!-- Image Placeholder (Right) -->
      <div class="md:w-1/2 flex justify-center">
          <div class="rounded-lg w-full h-64 md:h-80 flex items-center justify-center text-gray-400">
              <img src="/resources/img/gm.png" alt="Plant Gm" class="w-full h-auto object-contain">
          </div>
      </div>
  </div>
</section>

<!-- My Garden Section -->
<section class="py-12 px-6 bg-[#C7D9C6]">
  <div class="max-w-6xl mx-auto">
      <!-- Section Header -->
      <div class="flex justify-between items-center mb-8">
          <h2 class="text-2xl md:text-3xl font-bold text-[#0A5436]">Kebun Saya</h2>
          <button class="bg-[#3FAB5E] hover:bg-[#368F4F] text-white font-semibold py-2 px-4 rounded-lg transition-colors duration-300 flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
              </svg>
              Tambah Tanaman
          </button>
      </div>

      <!-- Plant Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Plant Card 1 -->
          <article class="bg-[#F2F1EB] rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 flex">
              <div class="w-1/3">
                  <img src="/resources/img/tomat_ceri.jpeg" alt="Tomato Plant" class="w-full h-full object-cover">
              </div>
              <div class="w-2/3 p-4">
                  <h3 class="text-xl font-semibold text-[#4E504D] mb-1">Tomat Cherry</h3>
                  <p class="text-sm text-[#4E504D] mb-2">Terakhir disiram: 2 hari lalu</p>
                  <p class="text-[#4E504D] text-sm">Flavor ir midway between garlic and o...</p>
              </div>
          </article>

          <!-- Plant Card 2 -->
          <article class="bg-[#F2F1EB] rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 flex">
              <div class="w-1/3">
                  <img src="/resources/img/basil.jpeg" alt="Basil Plant" class="w-full h-full object-cover">
              </div>
              <div class="w-2/3 p-4">
                  <h3 class="text-xl font-semibold text-[#4E504D] mb-1">Basil</h3>
                  <p class="text-sm text-[#4E504D] mb-2">Terakhir disiram: 1 hari lalu</p>
                  <p class="text-[#4E504D] text-sm">Flavor ir midway between garlic and o...</p>
              </div>
          </article>

          <!-- Plant Card 3 -->
          <article class="bg-[#F2F1EB] rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 flex">
              <div class="w-1/3">
                  <img src="/resources/img/rawit.jpeg" alt="Chili Plant" class="w-full h-full object-cover">
              </div>
              <div class="w-2/3 p-4">
                  <h3 class="text-xl font-semibold text-[#4E504D] mb-1">Cabai Rawit</h3>
                  <p class="text-sm text-[#4E504D] mb-2">Terakhir disiram: 3 hari lalu</p>
                  <p class="text-[#4E504D] text-sm">Flavor ir midway between garlic and o...</p>
              </div>
          </article>

          <!-- Row 2 -->
            <!-- Plant Card 4 -->
            <article class="bg-[#F2F1EB] rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 flex">
              <div class="w-1/3">
                  <img src="/resources/img/mint.jpeg" alt="Mint Plant" class="w-full h-full object-cover">
              </div>
              <div class="w-2/3 p-4">
                  <h3 class="text-xl font-semibold text-[#4E504D] mb-1">Daun Mint</h3>
                  <p class="text-sm text-[#4E504D] mb-2">Terakhir disiram: 1 hari lalu</p>
                  <p class="text-[#4E504D] text-sm">Flavor ir midway between garlic and o...</p>
              </div>
          </article>

          <!-- Plant Card 5 -->
          <article class="bg-[#F2F1EB] rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 flex">
              <div class="w-1/3">
                  <img src="/resources/img/selada.jpeg" alt="Lettuce Plant" class="w-full h-full object-cover">
              </div>
              <div class="w-2/3 p-4">
                  <h3 class="text-xl font-semibold text-[#4E504D] mb-1">Selada</h3>
                  <p class="text-sm text-[#4E504D] mb-2">Terakhir disiram: Hari ini</p>
                  <p class="text-[#4E504D] text-sm">Flavor ir midway between garlic and o...</p>
              </div>
          </article>

          <!-- Plant Card 6 -->
          <article class="bg-[#F2F1EB] rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 flex">
              <div class="w-1/3">
                  <img src="/resources/img/rosemary.jpeg" alt="Rosemary Plant" class="w-full h-full object-cover">
              </div>
              <div class="w-2/3 p-4">
                  <h3 class="text-xl font-semibold text-[#4E504D] mb-1">Rosemary</h3>
                  <p class="text-sm text-[#4E504D] mb-2">Terakhir disiram: 4 hari lalu</p>
                  <p class="text-[#4E504D] text-sm">Flavor ir midway between garlic and o...</p>
              </div>
          </article>
      </div>
  </div>
</section>

<!-- Plant Status Section -->
<section class="py-12 px-6 bg-[#C7D9C6]">
  <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-[#4E504D] mb-8">Status Tanaman</h2>
      
      <!-- Status Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Growth Status Card -->
          <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
              <div class="p-6">
                  <div class="flex items-center mb-4">
                      <div class="p-3 rounded-full bg-[#E1F5E9] mr-4">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#3FAB5E]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                          </svg>
                      </div>
                      <h3 class="text-xl font-semibold text-[#4E504D]">Pertumbuhan</h3>
                  </div>
                  <p class="text-[#4E504D] mb-4">Pantau perkembangan tanaman Anda secara berkala</p>
                  <a href="#" class="text-[#3FAB5E] font-medium flex items-center hover:text-[#368F4F] transition-colors">
                      Lihat detail
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                  </a>
              </div>
          </div>

          <!-- Harvest Status Card -->
          <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
              <div class="p-6">
                  <div class="flex items-center mb-4">
                      <div class="p-3 rounded-full bg-[#FFF3E0] mr-4">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#FFA726]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                          </svg>
                      </div>
                      <h3 class="text-xl font-semibold text-[#4E504D]">Panen</h3>
                  </div>
                  <p class="text-[#4E504D] mb-4">Jadwal dan tips panen untuk hasil optimal</p>
                  <a href="#" class="text-[#3FAB5E] font-medium flex items-center hover:text-[#368F4F] transition-colors">
                      Lihat detail
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                  </a>
              </div>
          </div>

          <!-- Pest/Disease Status Card -->
          <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
              <div class="p-6">
                  <div class="flex items-center mb-4">
                      <div class="p-3 rounded-full bg-[#FFEBEE] mr-4">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#EF5350]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                          </svg>
                      </div>
                      <h3 class="text-xl font-semibold text-[#4E504D]">Hama/Penyakit</h3>
                  </div>
                  <p class="text-[#4E504D] mb-4">Identifikasi dan atasi masalah tanaman Anda</p>
                  <a href="#" class="text-[#3FAB5E] font-medium flex items-center hover:text-[#368F4F] transition-colors">
                      Lihat detail
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                  </a>
              </div>
          </div>
      </div>
  </div>
</section>

<!-- Hero Section with Background Image -->
<section class="relative h-[400px] md:h-[500px] flex items-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
      <img src="/resources/img/gm_bg.png" alt="Garden Background" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-black/30"></div> <!-- Overlay for better text readability -->
  </div>
  
  <!-- Content -->
  <div class="relative z-10 max-w-6xl mx-auto px-6 w-full">
      <div class="max-w-xl">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 leading-tight">
              Kelola Kebun Pribadimu dengan Mudah
          </h1>
          <p class="text-lg md:text-xl text-white/90 mb-8 leading-relaxed">
              Lacak tanaman dan pantau perkembangan<br>
              kebunmu secara efisien!
          </p>
      </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-green-900 text-white pt-12 pb-8 px-6 md:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between gap-8 md:gap-12">
      
      <!-- Brand Info -->
      <div class="md:w-2/5">
        <h2 class="text-2xl font-bold mb-4">OxyPlant</h2>
        <p class="text-gray-300 mb-6">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam nec eros ut nunc luctus consectetur vel ac justo.
        </p>
      </div>
      
      <!-- Quick Links -->
      <div class="md:w-1/5">
        <h3 class="text-lg font-semibold mb-4">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="#" class="text-gray-300 hover:text-white transition">Home</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition">Garden Manager</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition">Plant Care</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition">Plant Info</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition">About</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition">Contact</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition">Login</a></li>
        </ul>
      </div>
      
      <!-- Contact Info -->
      <div class="md:w-2/5">
        <h3 class="text-lg font-semibold mb-4">Contact</h3>
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            +62 813-6060-6683
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            admin@gmail.com
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            FMIPA, Universitas Syiah Kuala,<br>Aceh, Indonesia.
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Copyright -->
    <div class="border-t border-green-800 mt-10 pt-6 text-center text-gray-400 text-sm">
      © 2025 OxyPlant, All Rights Reserved.
    </div>
  </div>
</footer>

</body>
</html>