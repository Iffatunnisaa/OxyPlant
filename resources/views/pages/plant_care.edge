<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OxyPlant</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="font-roboto"> 

<!-- Navigation -->
<nav class="bg-[#F2F1EB] shadow-sm py-4 px-6 sticky top-0 z-50" id="main-nav">
    <div class="max-w-6xl mx-auto flex justify-between items-center">
      <!-- Logo -->
      <div class="text-xl md:text-2xl font-bold text-[#0A5436] transition-colors duration-300">OxyPlant</div>
      
      <!-- Desktop Menu -->
      <div class="hidden md:flex space-x-4 lg:space-x-6 items-center">
        <a href="#" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">Home</a>
        <a href="#" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">Garden Manager</a>
        <a href="#" class="text-[#3FAB5E] font-semibold transition-colors duration-300 text-sm md:text-base">Plant Care</a>
        <a href="#" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">Plant Info</a>
        <a href="#" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">About</a>
      </div>
      
      <!-- Mobile Menu Button -->
      <button id="mobile-menu-button" class="md:hidden text-[#F1F0E9] focus:outline-none transition-colors duration-300">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
</nav>

<!-- Hero Section -->
<section class="bg-[#F2F1EB] py-16 md:py-24 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-8 md:gap-12">
      <!-- Text Content (Left) -->
      <div class="md:w-1/2 text-left">
          <h1 class="text-4xl md:text-4xl lg:text-5xl font-bold text-[#0A5436] mb-4">
              Plant Care
          </h1>
          <p class="mt-4 text-gray-600 max-w-lg leading-relaxed">
            "Rawat Tanaman, Rawat Kehidupan."<br>
            Panduan perawatan tanaman yang cerdas,<br>
            personal, dan mudah diikuti.<br>
          </p>
      </div>

      <!-- Image Placeholder (Right) -->
      <div class="md:w-1/2 flex justify-center">
          <div class="rounded-lg w-full h-64 md:h-80 flex items-center justify-center text-gray-400">
              <img src="/resources/img/pc.png" alt="Plant Gm" class="w-full h-auto object-contain">
          </div>
      </div>
  </div>
</section>

<!-- Plant Detail Section -->
<section class="py-12 px-6 bg-[#F2F1EB]">
  <div class="max-w-6xl mx-auto">
    <!-- Image and Text Row -->
    <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start mb-12">
      <!-- Image on Left -->
      <div class="w-full md:w-1/3">
        <img src="/resources/img/chives.png" alt="Chives Plant" class="w-full h-auto rounded-lg shadow-md object-cover">
      </div>

      <!-- Text Content on Right -->
      <div class="w-full md:w-2/3">
        <!-- Plant Header -->
        <div class="mb-6">
          <h1 class="text-3xl md:text-4xl font-bold text-[#0A5436]">Chives</h1>
          <p class="text-xl text-[#4E504D] italic">Allium Schoenoprasum</p>
        </div>

        <!-- Category Badge -->
        <div class="mb-6">
          <span class="bg-[#E1F5E9] text-[#0A5436] px-4 py-2 rounded-full text-sm font-medium">
            Category: Alliums
          </span>
        </div>

        <!-- Plant Description -->
        <div class="mb-6">
          <p class="text-[#4E504D] leading-relaxed">
            Chives Are A Member Of The Onion Family That Sport Beautiful Purple Flowers. They Are Cool-Season, Cold-Tolerant Perennials That Are Planted In Early Spring. Be Mindful When Planting This Herb, As It Will Take Over Your Garden If The Flowers Are Left To Ripen And Scatter Their Seeds. However, This Plant Is Easy To Dig Up And Move If It Overwhelms Your Garden.
          </p>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-b border-[#E0E0E0] my-8"></div>

    <!-- Plant Care Table -->
    <div class="mb-8 overflow-x-auto">
      <table class="w-full table-auto">
        <thead>
          <tr class="bg-[#F2F1EB]">
            <th class="px-4 py-3 text-left text-[#4E504D] font-medium">Spacing</th>
            <th class="px-4 py-3 text-left text-[#4E504D] font-medium">Depth</th>
            <th class="px-4 py-3 text-left text-[#4E504D] font-medium">Sun</th>
            <th class="px-4 py-3 text-left text-[#4E504D] font-medium">Water</th>
            <th class="px-4 py-3 text-left text-[#4E504D] font-medium">Season</th>
            <th class="px-4 py-3 text-left text-[#4E504D] font-medium">Frost</th>
            <th class="px-4 py-3 text-left text-[#4E504D] font-medium">Germination</th>
            <th class="px-4 py-3 text-left text-[#4E504D] font-medium">Sprout To Harvest</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="px-4 py-3 border-b border-[#E0E0E0] text-[#4E504D]">4/Square</td>
            <td class="px-4 py-3 border-b border-[#E0E0E0] text-[#4E504D]">1/4 In</td>
            <td class="px-4 py-3 border-b border-[#E0E0E0] text-[#4E504D]">Full Sun</td>
            <td class="px-4 py-3 border-b border-[#E0E0E0] text-[#4E504D]">1 In/Week</td>
            <td class="px-4 py-3 border-b border-[#E0E0E0] text-[#4E504D]">Perennial</td>
            <td class="px-4 py-3 border-b border-[#E0E0E0] text-[#4E504D]">Tolerant</td>
            <td class="px-4 py-3 border-b border-[#E0E0E0] text-[#4E504D]">2-3 Weeks</td>
            <td class="px-4 py-3 border-b border-[#E0E0E0] text-[#4E504D]">60-80 Days</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Divider -->
    <div class="border-b border-[#E0E0E0] my-8"></div>

    <!-- Read More Button -->
    <div class="text-center">
      <button class="bg-[#3FAB5E] hover:bg-[#368F4F] text-white font-semibold py-3 px-8 rounded-lg transition-colors duration-300 inline-flex items-center">
        Selengkapnya
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>
  </div>
</section>

<!-- Related Articles Section -->
<section class="py-12 px-6 bg-[#C7D9C6]">
  <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-[#0A5436] mb-8">Related Articles</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Article 1 -->
          <article class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden">
              <div class="p-6">
                <img src="/resources/img/artikel1.jpeg" alt="Article Image" class="w-full h-48 object-cover">
                  <h3 class="text-xl font-bold text-[#0A5436] mb-3">Tanaman Ubi dalam Planter Bag</h3>
                  <p class="text-[#4E504D] mb-4 line-clamp-3">Beberapa waktu yang lalu saya menanam ubi jalar menggunakan planter bag. Media tanannya menggunakan campuran pupuk kandang dan sekal...</p>
                  <p class="text-sm text-[#6B7280]">Feb 4, 2023</p>
              </div>
          </article>

          <!-- Article 2 -->
          <article class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden">
              <div class="p-6">
                <img src="/resources/img/artikel2.jpeg" alt="Article Image" class="w-full h-48 object-cover">
                  <h3 class="text-xl font-bold text-[#0A5436] mb-3">Agro Forestrium Tanaman Hiperakumulator Asia Tenggara</h3>
                  <p class="text-[#4E504D] mb-4 line-clamp-3">Tanaman hiperakumulator adalah tumbuhan yang memiliki kemampuan unik untuk menyerap, mengakumulasi, dan mentoleransi kadar tinggi...</p>
                  <p class="text-sm text-[#6B7280]">Jan 2021</p>
              </div>
          </article>

          <!-- Article 3 -->
          <article class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden">
              <div class="p-6">
                <img src="/resources/img/artikel3.jpeg" alt="Article Image" class="w-full h-48 object-cover">
                  <h3 class="text-xl font-bold text-[#0A5436] mb-3">Tanaman Nilam Penghasil Cuan</h3>
                  <p class="text-[#4E504D] mb-4 line-clamp-3">Nilam adalah tanaman penghasil minyak Atsiri yang jadi bahan baku pembuatan parfum.</p>
                  <p class="text-sm text-[#6B7280]">Sep 9, 2024</p>
              </div>
          </article>
      </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-green-900 text-white pt-12 pb-8 px-6 md:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between gap-8 md:gap-12">
        
        <!-- Brand Info -->
        <div class="md:w-2/5">
          <h2 class="text-2xl font-bold mb-4">OxyPlant</h2>
          <p class="text-gray-300 mb-6">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam nec eros ut nunc luctus consectetur vel ac justo.
          </p>
        </div>
        
        <!-- Quick Links -->
        <div class="md:w-1/5">
          <h3 class="text-lg font-semibold mb-4">Quick Links</h3>
          <ul class="space-y-2">
            <li><a href="#" class="text-gray-300 hover:text-white transition">Home</a></li>
            <li><a href="#" class="text-gray-300 hover:text-white transition">Garden Manager</a></li>
            <li><a href="#" class="text-gray-300 hover:text-white transition">Plant Care</a></li>
            <li><a href="#" class="text-gray-300 hover:text-white transition">Plant Info</a></li>
            <li><a href="#" class="text-gray-300 hover:text-white transition">About</a></li>
            <li><a href="#" class="text-gray-300 hover:text-white transition">Contact</a></li>
            <li><a href="#" class="text-gray-300 hover:text-white transition">Login</a></li>
          </ul>
        </div>
        
        <!-- Contact Info -->
        <div class="md:w-2/5">
          <h3 class="text-lg font-semibold mb-4">Contact</h3>
          <ul class="space-y-3 text-gray-300">
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              +62 813-6060-6683
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              admin@gmail.com
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              FMIPA, Universitas Syiah Kuala,<br>Aceh, Indonesia.
            </li>
          </ul>
        </div>
      </div>
      
      <!-- Copyright -->
      <div class="border-t border-green-800 mt-10 pt-6 text-center text-gray-400 text-sm">
        © 2025 OxyPlant, All Rights Reserved.
      </div>
    </div>
</footer>
</body>
</html>