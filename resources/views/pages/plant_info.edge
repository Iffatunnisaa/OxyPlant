                    <!-- Plant 3 - Sansevieria -->
                    <div class="flex-shrink-0 w-80 bg-white rounded-xl shadow-lg overflow-hidden snap-center relative">
                        <div class="p-6 pb-16"> <!-- Added pb-16 to make space for the image -->
