                            <img src="/resources/img/sansi.png" alt="Monstera Plant" class="w-full h-full object-contain">
                        </div>
                    </div>
                    
                    <!-- Plant 3 - Sansevieria -->
                    <div class="flex-shrink-0 w-80 bg-white rounded-xl shadow-lg overflow-hidden snap-center">
                        <div class="p-6">
                            <h3 class="text-xl font-bold text-green-700 mb-2">Sansevieria (Lidah Mertua)</h3>
