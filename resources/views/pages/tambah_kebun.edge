<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tambah Tanaman - OxyPlant</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="font-roboto bg-[#F2F1EB]">

<!-- Navigation -->
<nav class="bg-white shadow-sm py-4 px-6 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto flex justify-between items-center">
    <!-- Logo -->
    <div class="text-xl md:text-2xl font-bold text-[#0A5436]">
      <a href="{{ route('info.home') }}" class="hover:no-underline">OxyPlant</a>
    </div>
    
    <!-- Desktop Menu -->
    <div class="hidden md:flex space-x-4 lg:space-x-6 items-center">
      <a href="{{ route('info.home') }}" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">Home</a>
      <a href="{{ route('info.garden') }}" class="text-[#3FAB5E] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">Garden Manager</a>
      <a href="{{ route('info.care') }}" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">Plant Care</a>
      <a href="{{ route('info.plant') }}" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">Plant Info</a>
      <a href="{{ route('info.about') }}" class="text-[#4E504D] hover:text-green-300 transition-colors duration-300 text-sm md:text-base">About</a>
      <a href="{{ route('info.profil') }}" class="text-[#4E504D] hover:text-green-300 px-3 py-1 md:px-4 md:py-2 rounded-lg ml-2 md:ml-4 transition-colors duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </a>
    </div>
    
    <!-- Mobile Menu Button -->
    <button id="mobile-menu-button" class="md:hidden text-gray-600 focus:outline-none transition-colors duration-300" onclick="toggleMobileMenu()">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu (hidden by default) -->
  <div id="mobile-menu" class="hidden md:hidden pt-4 pb-2">
    <a href="{{ route('info.home') }}" class="block text-gray-700 hover:text-green-300 py-2 px-4">Home</a>
    <a href="{{ route('info.garden') }}" class="block text-gray-700 hover:text-green-300 py-2 px-4">Garden Manager</a>
    <a href="{{ route('info.care') }}" class="block text-gray-700 hover:text-green-300 py-2 px-4">Plant Care</a>
    <a href="{{ route('info.plant') }}" class="block text-gray-700 hover:text-green-300 py-2 px-4">Plant Info</a>
    <a href="{{ route('info.about') }}" class="block text-gray-700 hover:text-green-300 py-2 px-4">About</a>
    <a href="{{ route('info.profil') }}" class="block text-gray-700 hover:text-green-300 py-2 px-4">
      <div class="flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        Profile
      </div>
    </a>
  </div>
</nav>

<!-- Main Content -->
<main class="max-w-4xl mx-auto py-8 px-6">
  <div class="bg-white rounded-xl shadow-md overflow-hidden p-6 md:p-8">
    <!-- Header Section -->
    <div class="mb-8">
      <h1 class="text-2xl md:text-3xl font-bold text-[#0A5436] mb-2">Tambah Tanaman Baru</h1>
      <p class="text-gray-600">Isi form berikut untuk menambahkan tanaman baru ke kebun Anda</p>
    </div>

    <!-- Form Section -->
    <form action="{{ route('info.garden.store') }}" method="POST" enctype="multipart/form-data" class="space-y-6">
      
      <!-- Plant Name -->
      <div>
        <label for="plant_name" class="block text-sm font-medium text-gray-700 mb-1">Nama Tanaman</label>
        <input type="text" id="plant_name" name="plant_name" required
               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#3FAB5E] focus:border-[#3FAB5E] transition-colors"
               placeholder="Contoh: Tomat Cherry">
      </div>

      <!-- Plant Type -->
      <div>
        <label for="plant_type" class="block text-sm font-medium text-gray-700 mb-1">Jenis Tanaman</label>
        <select id="plant_type" name="plant_type" required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#3FAB5E] focus:border-[#3FAB5E] transition-colors">
          <option value="" disabled selected>Pilih jenis tanaman</option>
          <option value="sayuran">Sayuran</option>
          <option value="buah">Buah</option>
          <option value="herbal">Tanaman Herbal</option>
          <option value="hias">Tanaman Hias</option>
          <option value="lainnya">Lainnya</option>
        </select>
      </div>

      <!-- Planting Date -->
      <div>
        <label for="planting_date" class="block text-sm font-medium text-gray-700 mb-1">Tanggal Menanam</label>
        <input type="date" id="planting_date" name="planting_date" required
               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#3FAB5E] focus:border-[#3FAB5E] transition-colors">
      </div>

      <!-- Watering Schedule -->
      <div>
        <label for="watering_schedule" class="block text-sm font-medium text-gray-700 mb-1">Jadwal Penyiraman (hari)</label>
        <input type="number" id="watering_schedule" name="watering_schedule" min="1" required
               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#3FAB5E] focus:border-[#3FAB5E] transition-colors"
               placeholder="Contoh: 2 (setiap 2 hari)">
      </div>

      <!-- Plant Photo -->
      <div>
        <label for="plant_photo" class="block text-sm font-medium text-gray-700 mb-1">Foto Tanaman</label>
        <div class="mt-1 flex items-center">
          <input type="file" id="plant_photo" name="plant_photo" accept="image/*"
                 class="hidden" onchange="previewImage(event)">
          <label for="plant_photo" class="cursor-pointer bg-[#F2F1EB] hover:bg-gray-200 px-4 py-2 rounded-lg border border-gray-300 transition-colors">
            Pilih Gambar
          </label>
          <span id="file-name" class="ml-3 text-sm text-gray-500">Belum ada file dipilih</span>
        </div>
        <div id="image-preview" class="mt-2 hidden">
          <img id="preview" class="h-32 rounded-lg border border-gray-300">
        </div>
      </div>

      <!-- Additional Notes -->
      <div>
        <label for="notes" class="block text-sm font-medium text-gray-700 mb-1">Catatan Tambahan</label>
        <textarea id="notes" name="notes" rows="3"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#3FAB5E] focus:border-[#3FAB5E] transition-colors"
                  placeholder="Catatan tentang tanaman (opsional)"></textarea>
      </div>

      <!-- Form Actions -->
      <div class="flex justify-end space-x-4 pt-4">
        <a href="{{ route('info.garden') }}" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
          Batal
        </a>
        <button type="submit" class="px-6 py-2 bg-[#3FAB5E] hover:bg-[#368F4F] text-white rounded-lg transition-colors">
          Simpan Tanaman
        </button>
      </div>
    </form>
  </div>
</main>

<!-- Footer -->
<footer class="bg-green-900 text-white pt-12 pb-8 px-6 md:px-8 mt-12">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between gap-8 md:gap-12">
      
      <!-- Brand Info -->
      <div class="md:w-2/5">
        <h2 class="text-2xl font-bold mb-4">OxyPlant</h2>
        <p class="text-gray-300 mb-6">
          Platform manajemen kebun digital untuk membantu Anda merawat tanaman dengan lebih baik.
        </p>
      </div>
      
      <!-- Quick Links -->
      <div class="md:w-1/5">
        <h3 class="text-lg font-semibold mb-4">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="{{ route('info.home') }}" class="text-gray-300 hover:text-white transition">Home</a></li>
          <li><a href="{{ route('info.garden') }}" class="text-gray-300 hover:text-white transition">Garden Manager</a></li>
          <li><a href="{{ route('info.care') }}" class="text-gray-300 hover:text-white transition">Plant Care</a></li>
          <li><a href="{{ route('info.plant') }}" class="text-gray-300 hover:text-white transition">Plant Info</a></li>
        </ul>
      </div>
      
      <!-- Contact Info -->
      <div class="md:w-2/5">
        <h3 class="text-lg font-semibold mb-4">Contact</h3>
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            +62 813-6060-6683
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            admin@gmail.com
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            FMIPA, Universitas Syiah Kuala,<br>Aceh, Indonesia.
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Copyright -->
    <div class="border-t border-green-800 mt-10 pt-6 text-center text-gray-400 text-sm">
      © 2025 OxyPlant, All Rights Reserved.
    </div>
  </div>
</footer>

<script>
  // Mobile menu toggle function
  function toggleMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    menu.classList.toggle('hidden');
  }

  // Image preview function
  function previewImage(event) {
    const input = event.target;
    const fileName = input.files[0]?.name || 'Belum ada file dipilih';
    document.getElementById('file-name').textContent = fileName;
    
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      const preview = document.getElementById('preview');
      const previewContainer = document.getElementById('image-preview');
      
      reader.onload = function(e) {
        preview.src = e.target.result;
        previewContainer.classList.remove('hidden');
      }
      
      reader.readAsDataURL(input.files[0]);
    }
  }
</script>

</body>
</html>