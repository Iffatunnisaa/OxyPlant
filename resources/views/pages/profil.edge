<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - OxyPlant</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body class="bg-gray-50">
    <!-- Navigation yang disederhanakan -->
    <nav class="bg-green-800 shadow-sm py-4 px-6 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <!-- Back Button -->
            <a href="{{ route('info.home') }}" class="text-white hover:text-green-300 transition-colors duration-300">
                <i class="fas fa-arrow-left text-xl"></i>
            </a>
            
            <!-- Page Title -->
            <h1 class="text-white text-xl font-semibold">My Profile</h1>
            
            <!-- Empty div untuk balance layout -->
            <div class="w-6"></div>
        </div>
    </nav>

    <!-- Profile Content -->
    <div class="container mx-auto px-4 py-8 max-w-4xl">
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <!-- Profile Header -->
            <div class="bg-green-700 p-6 text-white">
                <div class="flex flex-col md:flex-row items-center">
                    <div class="w-32 h-32 rounded-full border-4 border-white bg-white shadow-lg overflow-hidden mb-4 md:mb-0 md:mr-6">
                        <img src="/resources/img/profil.jpeg" alt="Profile" class="w-full h-full object-cover">
                    </div>
                    <div class="text-center md:text-left">
                        <h1 class="text-2xl font-bold">Iffatun Nisa Nasrullah</h1>
                        <p class="text-green-200">Plant Enthusiast</p>
                        <div class="flex justify-center md:justify-start mt-2 space-x-2">
                            <span class="bg-green-600 text-xs px-2 py-1 rounded">Member since: June 2023</span>
                            <span class="bg-green-600 text-xs px-2 py-1 rounded">Premium</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Profile Body -->
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Left Column -->
                    <div class="md:col-span-1">
                        <div class="bg-gray-50 p-4 rounded-lg shadow-sm">
                            <h3 class="font-semibold text-lg mb-4 text-green-800 border-b pb-2">Personal Info</h3>
                            <ul class="space-y-3">
                                <li class="flex items-center">
                                    <i class="fas fa-envelope text-green-600 mr-2 w-5"></i>
                                    <span>iffa@gmail.com</span>
                                </li>
                                <li class="flex items-center">
                                    <i class="fas fa-map-marker-alt text-green-600 mr-2 w-5"></i>
                                    <span>Banda Aceh</span>
                                </li>
                                <li class="flex items-center">
                                    <i class="fas fa-calendar-alt text-green-600 mr-2 w-5"></i>
                                    <span>Joined June 12, 2023</span>
                                </li>
                            </ul>
                            
                            <h3 class="font-semibold text-lg mt-6 mb-4 text-green-800 border-b pb-2">Plant Stats</h3>
                            <div class="space-y-4">
                                <div>
                                    <div class="flex justify-between mb-1">
                                        <span class="text-sm font-medium">Plants Owned</span>
                                        <span class="text-sm">8</span>
                                    </div>
                                    <div class="w-full bg-gray-200 rounded-full h-2">
                                        <div class="bg-green-600 h-2 rounded-full" style="width: 40%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between mb-1">
                                        <span class="text-sm font-medium">Gardens</span>
                                        <span class="text-sm">3</span>
                                    </div>
                                    <div class="w-full bg-gray-200 rounded-full h-2">
                                        <div class="bg-green-600 h-2 rounded-full" style="width: 30%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between mb-1">
                                        <span class="text-sm font-medium">Care Logs</span>
                                        <span class="text-sm">24</span>
                                    </div>
                                    <div class="w-full bg-gray-200 rounded-full h-2">
                                        <div class="bg-green-600 h-2 rounded-full" style="width: 60%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="md:col-span-2">
                        <div class="bg-gray-50 p-4 rounded-lg shadow-sm mb-6">
                            <h3 class="font-semibold text-lg mb-4 text-green-800 border-b pb-2">My Gardens</h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <!-- Garden 1 -->
                                <div class="border rounded-lg overflow-hidden hover:shadow-md transition-shadow">
                                    <img src="https://images.unsplash.com/photo-1585320806297-9794b3e4eeae" alt="Indoor Garden" class="w-full h-32 object-cover">
                                    <div class="p-3">
                                        <h4 class="font-medium">Indoor Oasis</h4>
                                        <p class="text-sm text-gray-600">5 plants • Last cared: Today</p>
                                    </div>
                                </div>
                            </div>
                            <button class="mt-4 w-full py-2 bg-green-100 text-green-800 rounded-lg hover:bg-green-200 transition-colors">
                                <i class="fas fa-plus mr-2"></i>Add New Garden
                            </button>
                        </div>

                        <div class="bg-gray-50 p-4 rounded-lg shadow-sm">
                            <h3 class="font-semibold text-lg mb-4 text-green-800 border-b pb-2">Recent Activities</h3>
                            <div class="space-y-4">
                                <!-- Activity 1 -->
                                <div class="flex items-start">
                                    <div class="bg-green-100 p-2 rounded-full mr-3">
                                        <i class="fas fa-tint text-green-600"></i>
                                    </div>
                                    <div>
                                        <p class="font-medium">Watered Monstera</p>
                                        <p class="text-sm text-gray-600">Today at 08:30 AM</p>
                                    </div>
                                </div>
                                
                                <!-- Activity 2 -->
                                <div class="flex items-start">
                                    <div class="bg-green-100 p-2 rounded-full mr-3">
                                        <i class="fas fa-seedling text-green-600"></i>
                                    </div>
                                    <div>
                                        <p class="font-medium">Added new plant: Snake Plant</p>
                                        <p class="text-sm text-gray-600">Yesterday at 04:15 PM</p>
                                    </div>
                                </div>
                                
                                <!-- Activity 3 -->
                                <div class="flex items-start">
                                    <div class="bg-green-100 p-2 rounded-full mr-3">
                                        <i class="fas fa-cut text-green-600"></i>
                                    </div>
                                    <div>
                                        <p class="font-medium">Pruned Peace Lily</p>
                                        <p class="text-sm text-gray-600">2 days ago at 10:00 AM</p>
                                    </div>
                                </div>
                            </div>
                            <button class="mt-4 text-green-700 hover:text-green-900 text-sm font-medium">
                                View all activities <i class="fas fa-arrow-right ml-1"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Profile Footer -->
            <div class="bg-gray-100 px-6 py-4 flex justify-end">
                <button class="px-4 py-2 bg-green-700 text-white rounded-lg hover:bg-green-800 transition-colors mr-2">
                    <i class="fas fa-edit mr-2"></i>Edit Profile
                </button>
                <a href="{{ route('auth.login.show') }}" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors">
                    <i class="fas fa-sign-out-alt mr-2"></i>Sign Out
                </a>
            </div>
        </div>
    </div>
</body>
</html>