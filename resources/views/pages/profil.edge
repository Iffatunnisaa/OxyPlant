<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profil Saya - OxyPlant</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body class="bg-gray-50">
    <!-- Navigasi -->
    <nav class="bg-green-800 shadow-sm py-4 px-6 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <!-- Tombol Kembali -->
            <a href="{{ route('info.home') }}" class="text-white hover:text-green-300 transition-colors duration-300">
                <i class="fas fa-arrow-left text-xl"></i>
            </a>
            
            <!-- Judul Halaman -->
            <h1 class="text-white text-xl font-semibold">Profil Saya</h1>
            
            <!-- Div kosong untuk keseimbangan layout -->
            <div class="w-6"></div>
        </div>
    </nav>

    <!-- Konten Profil -->
    <div class="container mx-auto px-4 py-8 max-w-4xl">
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <!-- Header Profil -->
            <div class="bg-green-700 p-6 text-white">
                <div class="flex flex-col md:flex-row items-center">
                    <div class="w-32 h-32 rounded-full border-4 border-white bg-white shadow-lg overflow-hidden mb-4 md:mb-0 md:mr-6">
                        <img src="/resources/img/profil.jpeg" alt="Profil" class="w-full h-full object-cover">
                    </div>
                    <div class="text-center md:text-left">
                        <h1 class="text-2xl font-bold">Iffatun Nisa Nasrullah</h1>
                        <div class="flex justify-center md:justify-start mt-2 space-x-2">
                            <span class="bg-green-600 text-xs px-2 py-1 rounded">Anggota sejak: Juni 2023</span>
                            <span class="bg-green-600 text-xs px-2 py-1 rounded">Premium</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Isi Profil -->
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Kolom Kiri -->
                    <div class="md:col-span-1">
                        <div class="bg-gray-50 p-4 rounded-lg shadow-sm">
                            <h3 class="font-semibold text-lg mb-4 text-green-800 border-b pb-2">Info Pribadi</h3>
                            <ul class="space-y-3">
                                <li class="flex items-center">
                                    <i class="fas fa-envelope text-green-600 mr-2 w-5"></i>
                                    <span>iffa@gmail.com</span>
                                </li>
                                <li class="flex items-center">
                                    <i class="fas fa-map-marker-alt text-green-600 mr-2 w-5"></i>
                                    <span>Banda Aceh</span>
                                </li>
                                <li class="flex items-center">
                                    <i class="fas fa-calendar-alt text-green-600 mr-2 w-5"></i>
                                    <span>Bergabung 12 Juni 2023</span>
                                </li>
                            </ul>
                            
                            <h3 class="font-semibold text-lg mt-6 mb-4 text-green-800 border-b pb-2">Statistik Tanaman</h3>
                            <div class="space-y-4">
                                <div>
                                    <div class="flex justify-between mb-1">
                                        <span class="text-sm font-medium">Tanaman Dimiliki</span>
                                        <span class="text-sm">8</span>
                                    </div>
                                    <div class="w-full bg-gray-200 rounded-full h-2">
                                        <div class="bg-green-600 h-2 rounded-full" style="width: 40%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between mb-1">
                                        <span class="text-sm font-medium">Kebun</span>
                                        <span class="text-sm">3</span>
                                    </div>
                                    <div class="w-full bg-gray-200 rounded-full h-2">
                                        <div class="bg-green-600 h-2 rounded-full" style="width: 30%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between mb-1">
                                        <span class="text-sm font-medium">Log Perawatan</span>
                                        <span class="text-sm">24</span>
                                    </div>
                                    <div class="w-full bg-gray-200 rounded-full h-2">
                                        <div class="bg-green-600 h-2 rounded-full" style="width: 60%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Kolom Kanan -->
                    <div class="md:col-span-2">
                        <div class="bg-gray-50 p-4 rounded-lg shadow-sm mb-6">
                            <h3 class="font-semibold text-lg mb-4 text-green-800 border-b pb-2">Kebun Saya</h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <!-- Kebun 1 -->
                                <div class="border rounded-lg overflow-hidden hover:shadow-md transition-shadow">
                                    <img src="https://images.unsplash.com/photo-1585320806297-9794b3e4eeae" alt="Kebun Indoor" class="w-full h-32 object-cover">
                                    <div class="p-3">
                                        <h4 class="font-medium">Oasis Dalam Ruangan</h4>
                                        <p class="text-sm text-gray-600">5 tanaman • Dirawat terakhir: Hari ini</p>
                                    </div>
                                </div>
                            </div>
                            <button class="mt-4 w-full py-2 bg-green-100 text-green-800 rounded-lg hover:bg-green-200 transition-colors">
                                <i class="fas fa-plus mr-2"></i>Tambah Kebun Baru
                            </button>
                        </div>

                        <div class="bg-gray-50 p-4 rounded-lg shadow-sm">
                            <h3 class="font-semibold text-lg mb-4 text-green-800 border-b pb-2">Aktivitas Terbaru</h3>
                            <div class="space-y-4">
                                <!-- Aktivitas 1 -->
                                <div class="flex items-start">
                                    <div class="bg-green-100 p-2 rounded-full mr-3">
                                        <i class="fas fa-tint text-green-600"></i>
                                    </div>
                                    <div>
                                        <p class="font-medium">Menyiram Monstera</p>
                                        <p class="text-sm text-gray-600">Hari ini pukul 08:30</p>
                                    </div>
                                </div>
                                
                                <!-- Aktivitas 2 -->
                                <div class="flex items-start">
                                    <div class="bg-green-100 p-2 rounded-full mr-3">
                                        <i class="fas fa-seedling text-green-600"></i>
                                    </div>
                                    <div>
                                        <p class="font-medium">Menambahkan tanaman baru: Lidah Mertua</p>
                                        <p class="text-sm text-gray-600">Kemarin pukul 16:15</p>
                                    </div>
                                </div>
                                
                                <!-- Aktivitas 3 -->
                                <div class="flex items-start">
                                    <div class="bg-green-100 p-2 rounded-full mr-3">
                                        <i class="fas fa-cut text-green-600"></i>
                                    </div>
                                    <div>
                                        <p class="font-medium">Memangkas Pohon Kemuning</p>
                                        <p class="text-sm text-gray-600">2 hari lalu pukul 10:00</p>
                                    </div>
                                </div>
                            </div>
                            <button class="mt-4 text-green-700 hover:text-green-900 text-sm font-medium">
                                Lihat semua aktivitas <i class="fas fa-arrow-right ml-1"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer Profil -->
            <div class="bg-gray-100 px-6 py-4 flex justify-end">
                <button class="px-4 py-2 bg-green-700 text-white rounded-lg hover:bg-green-800 transition-colors mr-2">
                    <i class="fas fa-edit mr-2"></i>Edit Profil
                </button>
                <a href="{{ route('auth.login.show') }}" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors">
                    <i class="fas fa-sign-out-alt mr-2"></i>Keluar
                </a>
            </div>
        </div>
    </div>
</body>
</html>
