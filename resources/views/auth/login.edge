<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login OxyPlant</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      function togglePassword() {
        const passwordInput = document.getElementById('password');
        const eyeIcon = document.getElementById('eye-icon');
        if (passwordInput.type === 'password') {
          passwordInput.type = 'text';
          eyeIcon.textContent = '👁️';
        } else {
          passwordInput.type = 'password';
          eyeIcon.textContent = '🔒';
        }
      }
    </script>
  </head>
  <body class="flex min-h-screen">
    <!-- Bagian Kiri: Background Gambar Daun -->
    <div class="w-1/2 min-h-screen bg-cover bg-center" style="background-image: url('/resources/img/d2.jpeg');"></div>

    <!-- Bagian Kanan: Form Login -->
    <div class="w-1/2 flex items-center justify-center p-8" style="background-color: #F2F1EB;">
      <div class="w-full max-w-md flex flex-col"> <!-- Added flex-col -->
        <div class="text-center mb-8">
          <h2 class="text-3xl font-bold text-green-700 mb-2">Masuk ke Akun OxyPlant</h2>
          <p class="text-gray-600">Satu akun untuk semua produk OxyPlant</p>
        </div>

        <form class="space-y-4 flex-grow flex flex-col"> <!-- Made form flex container -->
          <div class="flex-grow"> <!-- Content area that grows -->
            <div>
              <label class="block text-gray-700 text-sm font-medium mb-1">Email</label>
              <input type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-transparent transition" placeholder="email@example.com" />
            </div>

            <div class="mt-4">
              <label class="block text-gray-700 text-sm font-medium mb-1">Kata Sandi</label>
              <div class="relative">
                <input id="password" type="password" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-transparent transition" placeholder="••••••••" />
                <button type="button" onclick="togglePassword()" class="absolute inset-y-0 right-3 flex items-center text-gray-500 hover:text-gray-700">
                  <span id="eye-icon">👁️</span>
                </button>
              </div>
              <div class="text-right mt-1">
                <a href="#" class="text-green-600 text-xs hover:underline">Lupa kata sandi?</a>
              </div>
            </div>
          </div>

          <div class="mt-auto text-center"> <!-- Button container at bottom -->
            <button class="w-full max-w-xs bg-gradient-to-r from-green-500 to-green-600 text-white py-2.5 px-4 rounded-lg font-medium hover:from-green-600 hover:to-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-opacity-50 transition shadow-sm">
              Masuk
            </button>
          </div>
        </form>

        <div class="text-center mt-6">
          <p class="text-sm text-gray-600">
            Belum punya akun? <a href="#" class="text-green-700 font-medium hover:underline">Daftar disini</a>
          </p>
        </div>
      </div>
    </div>
  </body>
</html>